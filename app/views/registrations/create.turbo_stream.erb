<%= turbo_stream.replace "registration_form" do %>
  <div class="text-center py-12 px-8">
    <svg class="mx-auto mb-6" width="56" height="56" viewBox="0 0 56 56" fill="none">
      <polygon points="28,5 33,21 50,21 37,31 42,47 28,37 14,47 19,31 6,21 23,21" fill="none" stroke="#d4789a" stroke-width="1.5"/>
    </svg>
    <h3 class="font-serif text-3xl font-normal mb-3 text-cream">Application received.</h3>
    <p class="text-sm text-muted mb-8">Someone with our staff will be in contact soon.<br>In the meantime — take a breath. You did something brave.</p>
    <a href="<%= intake_path %>" class="inline-block px-16 py-5 bg-pk text-white rounded-full font-sans text-lg font-light no-underline hover:bg-pk-dk transition-colors animate-glow">
      Help us understand you better &rarr;
    </a>
  </div>
<% end %>
