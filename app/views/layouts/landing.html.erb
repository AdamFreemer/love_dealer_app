<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for(:title) || "The Love Dealer — Jewish Matchmaking" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-bg text-cream font-sans text-base leading-relaxed">
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-12 py-5 bg-bg/85 backdrop-blur-md border-b border-border">
    <a href="/" class="font-serif text-xl text-cream no-underline">The Love <span class="text-pk">Dealer</span></a>
    <ul class="hidden md:flex gap-8 list-none">
      <li><a href="#services" class="text-xs tracking-widest text-muted hover:text-cream transition-colors no-underline">Services</a></li>
      <li><a href="#jamie" class="text-xs tracking-widest text-muted hover:text-cream transition-colors no-underline">About Jamie</a></li>
      <li><a href="#apply" class="text-xs tracking-widest text-muted hover:text-cream transition-colors no-underline">Apply</a></li>
      <% if user_signed_in? %>
        <li><a href="<%= customer_path %>" class="text-xs tracking-widest text-muted hover:text-cream transition-colors no-underline">My Profile</a></li>
        <% if current_user.admin? %>
          <li><a href="<%= admin_customers_path %>" class="text-xs tracking-widest text-muted hover:text-cream transition-colors no-underline">Admin</a></li>
        <% end %>
        <li><%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs tracking-widest text-muted hover:text-cream transition-colors no-underline" %></li>
      <% else %>
        <li><a href="<%= new_user_session_path %>" class="text-xs tracking-widest text-muted hover:text-cream transition-colors no-underline">Login</a></li>
      <% end %>
    </ul>
    <button onclick="document.getElementById('apply').scrollIntoView({behavior:'smooth'})" class="text-xs px-5 py-2 rounded-full border border-pk text-pk bg-transparent cursor-pointer font-sans hover:bg-pk hover:text-white transition-all">Get started</button>
  </nav>

  <% if notice.present? %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 bg-bg2 border border-pk/30 text-cream px-6 py-3 rounded-xl text-sm" data-controller="flash">
      <%= notice %>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 bg-bg2 border border-red-500/30 text-red-300 px-6 py-3 rounded-xl text-sm" data-controller="flash">
      <%= alert %>
    </div>
  <% end %>

  <%= yield %>

  <footer class="py-12 text-center border-t border-border">
    <div class="font-serif text-lg text-cream mb-2">The Love <span class="text-pk">Dealer</span></div>
    <p class="text-xs text-cream/20 tracking-widest">Private &middot; Curated &middot; For the Jewish community</p>
    <p class="text-xs text-cream/20 mt-4">&copy; 2026 The Love Dealer &middot; <a href="mailto:info@freemer.com" class="text-pk/40 hover:text-pk no-underline">Contact the administrator</a></p>
  </footer>
</body>
</html>
