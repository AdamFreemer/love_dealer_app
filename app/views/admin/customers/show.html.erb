<div class="mb-6">
  <a href="<%= admin_customers_path %>" class="text-sm text-gray-500 hover:text-gray-900 no-underline">&larr; All Customers</a>
</div>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="font-serif text-2xl"><%= @customer.full_name %></h1>
    <p class="text-sm text-gray-500 mt-1"><%= @customer.email %> &middot; <%= @customer.phone || "No phone" %></p>
  </div>
  <div class="flex items-center gap-3">
    <% status_colors = { "under_review" => "bg-yellow-100 text-yellow-800", "accepted" => "bg-green-100 text-green-800", "please_contact" => "bg-pink-100 text-pink-800" } %>
    <span class="px-3 py-1.5 rounded-full text-xs font-medium <%= status_colors[@customer.status] %>">
      <%= @customer.status.humanize %>
    </span>
    <a href="<%= edit_admin_customer_path(@customer) %>" class="px-4 py-2 bg-pk text-white rounded-lg text-xs no-underline hover:bg-pk-dk transition-colors">Edit</a>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <%# === BASIC INFO === %>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-xs uppercase tracking-wider text-gray-400 mb-4">Basic Information</h2>
    <dl class="space-y-3 text-sm">
      <div class="flex justify-between"><dt class="text-gray-500">Age</dt><dd><%= @customer.age || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Gender</dt><dd><%= @customer.gender&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Seeking</dt><dd><%= @customer.seeking&.sub("seeking_", "")&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Location</dt><dd><%= @customer.location || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Life Stage</dt><dd><%= @customer.life_stage&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Interest Level</dt><dd><%= @customer.interest_level&.humanize || "—" %></dd></div>
    </dl>
  </div>

  <%# === IDENTITY & VALUES === %>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-xs uppercase tracking-wider text-gray-400 mb-4">Identity & Values</h2>
    <dl class="space-y-3 text-sm">
      <div class="flex justify-between"><dt class="text-gray-500">Jewish</dt><dd><%= @customer.jewish? ? "Yes" : "No" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Jewish Identity</dt><dd><%= @customer.jewish_identity || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Political View</dt><dd><%= @customer.political_view&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Neurodivergent</dt><dd><%= @customer.neurodivergent&.humanize || "—" %></dd></div>
    </dl>
  </div>

  <%# === LIFESTYLE === %>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-xs uppercase tracking-wider text-gray-400 mb-4">Lifestyle</h2>
    <dl class="space-y-3 text-sm">
      <div class="flex justify-between"><dt class="text-gray-500">Alcohol</dt><dd><%= @customer.alcohol_use&.sub("alcohol_", "")&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Smoking</dt><dd><%= @customer.smoking&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Marijuana</dt><dd><%= @customer.marijuana_use&.sub("marijuana_", "")&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Open to Relocating</dt><dd><%= @customer.open_to_relocating&.sub("relocating_", "")&.humanize || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Zoom Consultation</dt><dd><%= @customer.open_to_zoom_consultation&.sub("zoom_", "")&.humanize || "—" %></dd></div>
    </dl>
  </div>

  <%# === SERVICES === %>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-xs uppercase tracking-wider text-gray-400 mb-4">Services & Agreements</h2>
    <div class="flex gap-2 flex-wrap mb-4">
      <% @customer.services.each do |service| %>
        <span class="px-3 py-1 rounded-full bg-pink-50 text-pk text-xs"><%= service.name %></span>
      <% end %>
      <% if @customer.services.empty? %>
        <span class="text-sm text-gray-400">None selected</span>
      <% end %>
    </div>
    <dl class="space-y-2 text-sm">
      <div class="flex justify-between"><dt class="text-gray-500">Consultation agreed</dt><dd><%= @customer.agrees_to_consultation? ? "Yes" : "No" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">No guarantee agreed</dt><dd><%= @customer.agrees_to_no_guarantee? ? "Yes" : "No" %></dd></div>
    </dl>
  </div>
</div>

<%# === TEXT RESPONSES === %>
<% text_sections = [
  ["About", @customer.about],
  ["Emotional Availability", @customer.emotional_availability],
  ["Cultural Values", @customer.cultural_values],
  ["Neurodivergent Details", @customer.neurodivergent_details],
  ["Upbringing", @customer.upbringing],
  ["Grief or Loss", @customer.grief_or_loss],
  ["Relationship Patterns", @customer.relationship_patterns],
  ["Partner Goals", @customer.partner_goals],
  ["Relationship Qualities", @customer.relationship_qualities],
  ["Comfort & Lifestyle", @customer.comfort_lifestyle],
  ["Luxury & Ease", @customer.luxury_relationship]
].select { |_, v| v.present? } %>

<% if text_sections.any? %>
  <div class="mt-6 bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-xs uppercase tracking-wider text-gray-400 mb-4">Detailed Responses</h2>
    <div class="space-y-5">
      <% text_sections.each do |label, value| %>
        <div>
          <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1"><%= label %></h3>
          <p class="text-sm text-gray-700 leading-relaxed"><%= value %></p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# === ADMIN NOTES === %>
<% if @customer.admin_notes.present? %>
  <div class="mt-6 bg-yellow-50 rounded-xl border border-yellow-200 p-6">
    <h2 class="text-xs uppercase tracking-wider text-yellow-600 mb-2">Admin Notes</h2>
    <p class="text-sm text-yellow-900 leading-relaxed"><%= @customer.admin_notes %></p>
  </div>
<% end %>
