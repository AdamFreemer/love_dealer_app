<div data-controller="batch-select">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-serif text-2xl">Customers</h1>
    <div class="flex items-center gap-4">
      <div class="hidden flex items-center gap-2" data-batch-select-target="batchActions">
        <%= form_with url: batch_destroy_admin_customers_path, method: :delete, data: { batch_select_target: "softForm" } do %>
          <button type="button" data-action="click->batch-select#submitSoftBatch" data-batch-select-target="softCount" class="px-4 py-2 bg-red-600 text-white rounded-lg text-xs hover:bg-red-700 transition-colors cursor-pointer">
            Delete selected
          </button>
        <% end %>
        <%= form_with url: batch_hard_destroy_admin_customers_path, method: :delete, data: { batch_select_target: "hardForm" } do %>
          <button type="button" data-action="click->batch-select#submitHardBatch" data-batch-select-target="hardCount" class="px-4 py-2 bg-red-950 text-white rounded-lg text-xs hover:bg-black transition-colors cursor-pointer border border-red-700">
            Permanently delete selected
          </button>
        <% end %>
      </div>
      <span class="text-sm text-gray-500"><%= @customers.count %> total</span>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 w-10">
            <input type="checkbox" data-batch-select-target="selectAll" data-action="change->batch-select#toggleAll" class="w-4 h-4 accent-pk">
          </th>
          <th class="text-left px-6 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Name</th>
          <th class="text-left px-6 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Email</th>
          <th class="text-left px-6 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Age</th>
          <th class="text-left px-6 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Location</th>
          <th class="text-left px-6 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Status</th>
          <th class="text-left px-6 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Applied</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @customers.each do |customer| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <input type="checkbox" value="<%= customer.id %>" data-batch-select-target="checkbox" data-action="change->batch-select#toggleOne" class="w-4 h-4 accent-pk">
            </td>
            <td class="px-6 py-4 font-medium"><%= customer.full_name %></td>
            <td class="px-6 py-4 text-gray-500"><%= customer.email %></td>
            <td class="px-6 py-4 text-gray-500"><%= customer.age %></td>
            <td class="px-6 py-4 text-gray-500"><%= customer.location || "—" %></td>
            <td class="px-6 py-4">
              <% status_colors = { "under_review" => "bg-yellow-100 text-yellow-800", "accepted" => "bg-green-100 text-green-800", "please_contact" => "bg-pink-100 text-pink-800" } %>
              <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= status_colors[customer.status] %>">
                <%= customer.status.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 text-gray-400"><%= customer.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-right space-x-3">
              <a href="<%= admin_customer_path(customer) %>" class="text-pk hover:underline no-underline text-xs">View</a>
              <%= link_to "Delete", admin_customer_path(customer), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete #{customer.full_name}?" }, class: "text-red-500 hover:underline no-underline text-xs" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @customers.empty? %>
      <div class="py-12 text-center text-gray-400 text-sm">No customers yet.</div>
    <% end %>
  </div>
</div>
