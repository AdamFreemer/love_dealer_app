<%= form_with(model: user, url: registrations_path, class: "text-left", data: { controller: "service-toggle" }) do |f| %>
  <% if user.errors.any? %>
    <div class="mb-6 p-4 bg-red-900/20 border border-red-500/30 rounded-xl text-red-300 text-sm">
      <% user.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div class="flex flex-col">
      <label class="text-xs uppercase tracking-widest text-muted mb-1">First name</label>
      <%= f.text_field :first_name, placeholder: "Rachel", required: true, class: "bg-cream/5 border border-border rounded-lg px-4 py-3 text-cream font-sans text-sm outline-none focus:border-pk transition-colors" %>
    </div>
    <div class="flex flex-col">
      <label class="text-xs uppercase tracking-widest text-muted mb-1">Last name</label>
      <%= f.text_field :last_name, placeholder: "Goldman", required: true, class: "bg-cream/5 border border-border rounded-lg px-4 py-3 text-cream font-sans text-sm outline-none focus:border-pk transition-colors" %>
    </div>
  </div>

  <div class="flex flex-col mb-4">
    <label class="text-xs uppercase tracking-widest text-muted mb-1">Email address</label>
    <%= f.email_field :email, placeholder: "you@email.com", required: true, class: "bg-cream/5 border border-border rounded-lg px-4 py-3 text-cream font-sans text-sm outline-none focus:border-pk transition-colors" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div class="flex flex-col">
      <label class="text-xs uppercase tracking-widest text-muted mb-1">Age</label>
      <%= f.select :age, options_for_select([["Select...", ""]] + (18..99).map { |n| [n, n] }, user.age), {}, required: true, class: "bg-cream/5 border border-border rounded-lg px-4 py-3 text-cream font-sans text-sm outline-none focus:border-pk transition-colors appearance-none", style: "background-color: rgba(232,221,212,0.05)" %>
    </div>
    <div class="flex flex-col">
      <label class="text-xs uppercase tracking-widest text-muted mb-1">I identify as</label>
      <%= f.select :gender, options_for_select([["Select...", ""], ["A woman", "woman"], ["A man", "man"], ["Non-binary", "non_binary"]], user.gender), {}, required: true, class: "bg-cream/5 border border-border rounded-lg px-4 py-3 text-cream font-sans text-sm outline-none focus:border-pk transition-colors appearance-none", style: "background-color: rgba(232,221,212,0.05)" %>
    </div>
  </div>

  <div class="flex flex-col mb-4">
    <label class="text-xs uppercase tracking-widest text-muted mb-1">I'm seeking</label>
    <%= f.select :seeking, options_for_select([["Select...", ""], ["Women", "seeking_woman"], ["Men", "seeking_man"], ["Non-binary", "seeking_non_binary"], ["Open to all", "seeking_all"]], user.seeking), {}, required: true, class: "bg-cream/5 border border-border rounded-lg px-4 py-3 text-cream font-sans text-sm outline-none focus:border-pk transition-colors appearance-none", style: "background-color: rgba(232,221,212,0.05)" %>
  </div>

  <div class="flex flex-col mb-4">
    <label class="text-xs uppercase tracking-widest text-muted mb-1">I'm interested in <span class="text-pk/60 normal-case tracking-normal">(select at least one)</span></label>
    <div class="flex gap-2 flex-wrap" data-service-toggle-target="container">
      <% services.each do |service| %>
        <button type="button"
                class="px-4 py-2 rounded-full border border-border bg-transparent text-muted font-sans text-xs cursor-pointer transition-all hover:border-pk/50"
                data-action="click->service-toggle#toggle"
                data-service-id="<%= service.id %>">
          <%= service.name %>
        </button>
      <% end %>
    </div>
    <p class="hidden text-pk text-xs mt-2" data-service-toggle-target="error">Please select at least one service.</p>
    <% services.each do |service| %>
      <%= hidden_field_tag "user[service_ids][]", "", id: "service_hidden_#{service.id}", disabled: true, data: { service_toggle_target: "hiddenField", service_id: service.id } %>
    <% end %>
  </div>

  <div class="flex flex-col mb-4">
    <label class="text-xs uppercase tracking-widest text-muted mb-1">Tell us about yourself &amp; what you're looking for</label>
    <%= f.text_area :about, placeholder: "Share anything that feels relevant — your background, what matters to you in a partner, where you are in life right now...", required: true, class: "bg-cream/5 border border-border rounded-lg px-4 py-3 text-cream font-sans text-sm outline-none focus:border-pk transition-colors resize-y min-h-28" %>
  </div>

  <%= f.submit "Submit my application", class: "w-full mt-6 py-4 bg-pk text-white border-none rounded-full font-sans text-sm cursor-pointer hover:bg-pk-dk transition-colors" %>
<% end %>
