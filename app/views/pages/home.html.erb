<!-- HERO -->
<section class="min-h-screen flex items-center justify-center text-center pt-32 pb-20 px-8 relative overflow-hidden" id="hero">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_40%,rgba(212,120,154,0.08)_0%,transparent_70%)]"></div>
  <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[480px] h-[480px] opacity-[0.03] pointer-events-none" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
    <polygon points="100,10 118,65 175,65 128,100 145,155 100,122 55,155 72,100 25,65 82,65" fill="none" stroke="white" stroke-width="0.8"/>
    <polygon points="100,30 113,72 157,72 122,97 135,139 100,116 65,139 78,97 43,72 87,72" fill="none" stroke="white" stroke-width="0.5"/>
  </svg>
  <div class="relative z-10">
    <div class="text-xs tracking-[0.2em] uppercase text-pk mb-6">A Jewish matchmaking experience &middot; Personal &middot; Intentional</div>
    <h1 class="font-serif text-[clamp(2.8rem,5.5vw,4.2rem)] font-normal leading-tight text-cream mb-6 max-w-2xl mx-auto">Meaningful connections,<br>not <em class="text-pk italic">swiping.</em></h1>
    <p class="text-base text-muted max-w-md mx-auto mb-10 leading-relaxed">Boutique Jewish matchmaking — human-curated, relationship-first, built for people who are serious about finding their person.</p>
    <div class="flex gap-4 justify-center flex-wrap">
      <button onclick="document.getElementById('apply').scrollIntoView({behavior:'smooth'})" class="px-8 py-3.5 bg-pk text-white border-none rounded-full font-sans text-sm cursor-pointer hover:bg-pk-dk transition-colors">Apply to work with us</button>
      <button onclick="document.getElementById('services').scrollIntoView({behavior:'smooth'})" class="px-8 py-3.5 bg-transparent text-cream border border-border rounded-full font-sans text-sm cursor-pointer hover:border-pk transition-colors">Learn more</button>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="py-24 px-8 max-w-[1100px] mx-auto" id="services">
  <div class="text-xs tracking-[0.2em] uppercase text-pk text-center mb-4">What we offer</div>
  <h2 class="font-serif text-[clamp(1.8rem,3vw,2.6rem)] font-normal text-center mb-14 text-cream">Three ways to find your match</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-bg2 border border-border rounded-2xl p-9 hover:border-pk/30 transition-colors">
      <div class="w-11 h-11 rounded-xl bg-pk/10 flex items-center justify-center mb-5">
        <svg class="w-5 h-5 stroke-pk fill-none stroke-[1.5]" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <h3 class="font-serif text-xl font-normal mb-2 text-cream">Personal Matchmaking</h3>
      <p class="text-sm text-muted leading-relaxed">One-on-one introductions, curated by a human who knows your community. No algorithm, no swiping — just thoughtful, intentional matches.</p>
      <a class="inline-block mt-5 text-xs text-pk no-underline tracking-wide" href="#apply">Apply &rarr;</a>
    </div>
    <div class="bg-bg2 border border-border rounded-2xl p-9 hover:border-pk/30 transition-colors">
      <div class="w-11 h-11 rounded-xl bg-pk/10 flex items-center justify-center mb-5">
        <svg class="w-5 h-5 stroke-pk fill-none stroke-[1.5]" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <h3 class="font-serif text-xl font-normal mb-2 text-cream">Dating Coaching</h3>
      <p class="text-sm text-muted leading-relaxed">One-on-one sessions to refine your approach, sharpen your profile, and show up confidently on dates. Tailored to who you are.</p>
      <a class="inline-block mt-5 text-xs text-pk no-underline tracking-wide" href="#apply">Learn more &rarr;</a>
    </div>
    <div class="bg-bg2 border border-border rounded-2xl p-9 hover:border-pk/30 transition-colors">
      <div class="w-11 h-11 rounded-xl bg-pk/10 flex items-center justify-center mb-5">
        <svg class="w-5 h-5 stroke-pk fill-none stroke-[1.5]" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <h3 class="font-serif text-xl font-normal mb-2 text-cream">Group Video Mixers</h3>
      <p class="text-sm text-muted leading-relaxed">Curated virtual gatherings for Jewish singles — small groups, warm energy, low pressure. A great first step into the process.</p>
      <a class="inline-block mt-5 text-xs text-pk no-underline tracking-wide" href="#apply">Join a mixer &rarr;</a>
    </div>
  </div>
</section>

<!-- MEET JAMIE -->
<section class="py-24 px-8 bg-bg2 border-t border-b border-border" id="jamie">
  <div class="max-w-[1000px] mx-auto grid grid-cols-1 md:grid-cols-[420px_1fr] gap-20 items-center">
    <div class="relative">
      <div class="relative inline-block">
        <div class="absolute inset-[-1px] rounded-[220px_220px_200px_200px] bg-gradient-to-br from-pk/30 to-transparent"></div>
        <%= image_tag "jamie1.png", alt: "Jamie Levine, Lead Matchmaker", class: "relative z-10 w-full max-w-[360px] block mx-auto drop-shadow-2xl" %>
        <div class="absolute bottom-[-1.5rem] right-[-1rem] bg-bg border border-border rounded-xl p-4 max-w-[220px] z-20">
          <p class="font-serif italic text-sm text-cream leading-snug">"Every introduction I make, I make as if I'm setting up my closest friend."</p>
          <span class="block text-xs text-pk mt-1 tracking-wider">— Jamie Levine</span>
        </div>
      </div>
    </div>
    <div>
      <div class="text-xs tracking-[0.2em] uppercase text-pk mb-4">Your matchmaker</div>
      <h2 class="font-serif text-[clamp(1.8rem,3vw,2.6rem)] font-normal mb-5 text-cream">Meet Jamie Levine</h2>
      <p class="text-sm text-muted leading-relaxed mb-4">Jamie has spent over a decade building relationships inside the Jewish community — as a connector, an advisor, and now as a professional matchmaker. She founded The Love Dealer because she believed the Jewish dating world deserved something more personal than an app.</p>
      <p class="text-sm text-muted leading-relaxed mb-4">Her approach is direct, warm, and deeply knowledgeable about the nuances that matter: observance levels, family dynamics, cultural backgrounds, what "serious" actually means to different people.</p>
      <p class="text-cream font-serif italic text-lg">She doesn't just find you a date. She finds you a partner.</p>
      <div class="flex gap-8 mt-8 border-t border-border pt-7">
        <div>
          <span class="font-serif text-3xl text-pk block leading-none">100%</span>
          <div class="text-xs text-muted mt-1">Human-curated</div>
        </div>
        <div>
          <span class="font-serif text-3xl text-pk block leading-none">3</span>
          <div class="text-xs text-muted mt-1">Ways to work together</div>
        </div>
        <div>
          <span class="font-serif text-3xl text-pk block leading-none">48h</span>
          <div class="text-xs text-muted mt-1">Response time</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PHILOSOPHY -->
<section class="py-24 px-8 max-w-[900px] mx-auto text-center" id="philosophy">
  <div class="text-xs tracking-[0.2em] uppercase text-pk mb-4">Our approach</div>
  <h2 class="font-serif text-[clamp(1.8rem,3vw,2.6rem)] font-normal mb-12 text-cream">A matchmaker who knows your world</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="p-8">
      <span class="font-serif text-4xl text-pk opacity-40 block mb-2">01</span>
      <h4 class="text-sm font-medium mb-2 text-cream">Rooted in community</h4>
      <p class="text-xs text-muted leading-relaxed">Jewish dating has its own language. Observance, family, heritage — we understand what matters and why.</p>
    </div>
    <div class="p-8">
      <span class="font-serif text-4xl text-pk opacity-40 block mb-2">02</span>
      <h4 class="text-sm font-medium mb-2 text-cream">No algorithm. Ever.</h4>
      <p class="text-xs text-muted leading-relaxed">Every introduction is made by a human who has spoken with both people and believes in the potential.</p>
    </div>
    <div class="p-8">
      <span class="font-serif text-4xl text-pk opacity-40 block mb-2">03</span>
      <h4 class="text-sm font-medium mb-2 text-cream">Your pace, your terms</h4>
      <p class="text-xs text-muted leading-relaxed">Whether you want one careful introduction or ongoing support — we meet you where you are.</p>
    </div>
  </div>
</section>

<!-- FORM -->
<%= tag.meta name: "turbo-cache-control", content: "no-cache" %>
<section class="py-24 px-8 bg-bg2 border-t border-border" id="apply">
  <div class="max-w-xl mx-auto text-center">
    <div class="text-xs tracking-[0.2em] uppercase text-pk mb-4">Get started</div>
    <h2 class="font-serif text-[clamp(1.8rem,3vw,2.6rem)] font-normal mb-3 text-cream">Tell us about yourself</h2>
    <p class="text-sm text-muted mb-2">Fill out the form below and Jamie will follow up within 48 hours. All information is kept strictly private.</p>
    <p class="text-xs text-pk/60 mb-10">All fields are required</p>

    <%= turbo_frame_tag "registration_form" do %>
      <%= render "pages/form", user: @user, services: @services %>
    <% end %>
  </div>
</section>
